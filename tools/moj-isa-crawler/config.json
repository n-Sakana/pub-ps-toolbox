{
  "allowed_prefixes": [
    "https://www.moj.go.jp/isa/"
  ],
  "same_netloc_only": true,
  "default_output": "moj_isa_crawl.xlsx",
  "default_download_dir": "downloads/pdfs",
  "default_log_file": "logs/moj_isa_crawler.log",
  "default_error_log_file": "logs/moj_isa_errors.txt",
  "log_level": "INFO",
  "progress_every_pages": 1,
  "progress_every_pdfs": 25,
  "download_pdfs_by_default": false,
  "probe_pdfs_by_default": false,
  "timeout": 30,
  "sleep": 0.2,
  "retries": 2,
  "max_pages": null,
  "max_depth": null,
  "strict": false,
  "default_graph_dir": "graphs",
  "generate_graphs_by_default": true
}
